{
  "name": "mythos-trading-agent",
  "version": "0.1.0",
  "description": "Autonomous crypto trading agent — Phase 0 MVP",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsx watch src/main/index.ts",
    "start": "node dist/main/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "data:fetch": "tsx src/data/cli.ts fetch",
    "data:integrity": "tsx src/data/cli.ts integrity",
    "report:backtest": "tsx src/reporting/cli.ts backtest",
    "report:verdict": "tsx src/reporting/cli.ts verdict"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "@upstash/redis": "^1.34.0",
    "bullmq": "^5.12.0",
    "ccxt": "^4.4.0",
    "dotenv": "^16.4.5",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.14.0",
    "@typescript-eslint/parser": "^7.14.0",
    "tsx": "^4.15.6",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "packageManager": "pnpm@9.4.0"
}
