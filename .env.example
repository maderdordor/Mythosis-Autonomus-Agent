# ==============================================================================
# MYTHOS TRADING AGENT — Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git. This file (.env.example) is safe to commit.
# ==============================================================================


# ==============================================================================
# DATABASE — Supabase
# ==============================================================================
# Find these in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Direct PostgreSQL connection (for Python engine via psycopg2)
# Find in: Supabase Dashboard → Project Settings → Database → Connection String
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.YOUR_PROJECT_REF.supabase.co:5432/postgres


# ==============================================================================
# CACHE — Upstash Redis (managed)
# ==============================================================================
# Find these in: Upstash Console → Your Database → REST API
UPSTASH_REDIS_REST_URL=https://YOUR_DATABASE_NAME.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token-here

# Standard Redis URL (used by BullMQ job queue)
# Format: rediss://default:[TOKEN]@[HOST]:6380
REDIS_URL=rediss://default:your-upstash-rest-token-here@YOUR_DATABASE_NAME.upstash.io:6380


# ==============================================================================
# EXCHANGE — Bybit
# ==============================================================================
# Phase 0: API keys are OPTIONAL.
#   OHLCV data is fetched from Bybit PUBLIC endpoints (no auth required).
#   Leave these as placeholders — the agent will use public endpoints.
#
# Phase 2+ (live trading): Fill in your API keys.
#   IMPORTANT: The API key MUST be read-only / trading-only.
#              NEVER enable withdrawal permission. (ref: brief Section 12)
#
BYBIT_API_KEY=your-bybit-api-key-here
BYBIT_API_SECRET=your-bybit-api-secret-here
BYBIT_TESTNET=true


# ==============================================================================
# BACKTEST & EXECUTION REALISM
# ==============================================================================
# These values mirror Bybit USDT perp real-world costs.
# Do NOT change these to make backtests look better. (ref: brief Section 8.4)
MAKER_FEE=0.0002
TAKER_FEE=0.00055
SLIPPAGE=0.0005
ENTRY_DELAY_BARS=1
EXIT_DELAY_BARS=1

# Fee viability check: avg_gross_edge >= FEE_VIABILITY_MULTIPLIER * round_trip_cost
# Any strategy failing this is auto-FAILED. Do not lower this value. (ref: brief Section 3.4)
FEE_VIABILITY_MULTIPLIER=2


# ==============================================================================
# RISK ENGINE
# ==============================================================================
# Hard risk limits. These are enforced in code, not prompts.
# Breaching any of these triggers an automatic kill switch. (ref: brief Section 8.13)
MAX_RISK_PER_TRADE=0.005        # 0.5% of equity per trade
MAX_DAILY_LOSS=0.02             # 2% daily loss hard wall
MAX_WEEKLY_LOSS=0.05            # 5% weekly loss limit
MAX_ACCOUNT_DRAWDOWN=0.10       # 10% account drawdown → hard shutdown
MAX_LEVERAGE=2                  # Effective leverage cap
MAX_OPEN_POSITIONS=3            # Max concurrent positions
LOSS_STREAK_COOLDOWN=3          # Cooldown after N consecutive losses
KILL_SWITCH=true                # Global kill switch (always true)


# ==============================================================================
# TRADE FREQUENCY TARGETS (ref: brief Section 3.2)
# ==============================================================================
# These are OUTPUTS of a validated edge, not inputs.
# The system monitors these but does not force trades to meet them.
MIN_TRADE_FREQUENCY_PER_DAY=5
MAX_TRADE_FREQUENCY_PER_DAY=30


# ==============================================================================
# DECISION MODE (ref: brief Section 5)
# ==============================================================================
# HARDCODED     = pure rule engine, zero LLM in trade path (default, Phase 0)
# LLM_ADVISORY  = rule engine executes, LLM logs verdict but has zero influence
# LLM_ACTIVE    = LLM can veto/reduce, never initiate or increase
DECISION_MODE=hardcoded

LLM_SIGNAL_PROVIDER=deepseek
LLM_MACRO_PROVIDER=grok
LLM_TIMEOUT_MS=8000
LLM_FALLBACK=hardcoded
LLM_MAX_DAILY_CALLS=500
LLM_MAX_MONTHLY_USD=50
GROK_POLL_INTERVAL_MINUTES=30


# ==============================================================================
# LIVE / PAPER TRADING
# ==============================================================================
# Phase 0 defaults — all off. DO NOT change until Gates are passed.
LIVE_TRADING=false
PAPER_TRADING=false

# MANUAL     = agent proposes, human approves every trade
# SEMI_AUTO  = agent executes entries, human approves size increases only
# FULL_AUTO  = fully autonomous (requires Gate 3 + 8.12 promotion criteria)
EXECUTION_MODE=manual


# ==============================================================================
# NANSEN SMART MONEY (ref: brief Section 9)
# ==============================================================================
# Phase 0: DISABLED for trading. nansenSnapshotCollector may run passively.
# Phase 1+: Enable and configure.
NANSEN_API_KEY=your-nansen-api-key-here
NANSEN_BASE_URL=https://api.nansen.ai
NANSEN_ENABLED=false
NANSEN_CACHE_TTL_SECONDS=60
NANSEN_WALLET_LABEL_CACHE_HOURS=24
NANSEN_MAX_DAILY_CREDITS=5000

# false = fail-closed in live trading (no Nansen data = no entry where required)
# true  = fail-open (for paper/dry-run only)
NANSEN_FAIL_OPEN=false

# Score thresholds (ref: brief Section 9.8)
NANSEN_MIN_SMART_MONEY_SCORE=70
NANSEN_MIN_WALLET_CREDIBILITY=65
NANSEN_MIN_NETFLOW_SCORE=60
NANSEN_BLOCK_ON_DISTRIBUTION=true


# ==============================================================================
# COINGLASS MARKET SCANNER (ref: brief Section 10)
# ==============================================================================
# Phase 0: NOT active. Schema built, integration in Phase 1.
COINGLASS_API_KEY=your-coinglass-api-key-here
COINGLASS_ENABLED=false
COINGLASS_SCAN_INTERVAL_SECONDS=120
COINGLASS_TOP_N=300
VOLUME_SPIKE_MULTIPLIER=3
COINGLASS_MAX_DAILY_CALLS=20000


# ==============================================================================
# TELEGRAM COMMAND & CONTROL (ref: brief Section 11)
# ==============================================================================
# Phase 0: NOT active. Built in Phase 1.
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
# Comma-separated Telegram user IDs allowed to issue commands
TELEGRAM_ADMIN_IDS=123456789,987654321
TELEGRAM_CONFIRM_HIGH_IMPACT=true


# ==============================================================================
# LOGGING
# ==============================================================================
# Levels: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
# Formats: json (production) | pretty (development)
LOG_FORMAT=pretty
